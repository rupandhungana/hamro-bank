<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bankingsystem.controller.RegisterController"
           style="-fx-background-color: #F8FAFC;">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;">
        <VBox alignment="CENTER" spacing="24" maxWidth="600" style="-fx-padding: 40 20;">
            <StackPane.margin><Insets bottom="40" top="40"/></StackPane.margin>
            
            <!-- Brand Icon -->
            <VBox alignment="CENTER" spacing="12">
                <StackPane styleClass="logo-badge" prefWidth="48" prefHeight="48">
                    <Label text="BF" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </StackPane>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Create Account" styleClass="hero-title" style="-fx-font-size: 26;"/>
                    <Label text="Join the next generation of banking" styleClass="tagline"/>
                </VBox>
            </VBox>

            <!-- Register Card -->
            <VBox styleClass="card" spacing="24" maxWidth="500">
                <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

                <VBox spacing="16">
                    <!-- Personal Info Section -->
                    <Label text="PERSONAL DETAILS" styleClass="form-section-title"/>
                    
                    <VBox spacing="8">
                        <Label text="FULL NAME" styleClass="form-label"/>
                        <TextField fx:id="fullNameField" promptText="Enter your legal full name" styleClass="input"/>
                    </VBox>

                    <HBox spacing="12">
                       <VBox spacing="8" HBox.hgrow="ALWAYS" maxWidth="150">
                           <Label text="GENDER" styleClass="form-label"/>
                           <ComboBox fx:id="genderCombo" maxWidth="Infinity" styleClass="combo-box"/>
                       </VBox>
                       <VBox spacing="8" HBox.hgrow="ALWAYS">
                           <Label text="DATE OF BIRTH" styleClass="form-label"/>
                           <TextField fx:id="dobField" promptText="YYYY-MM-DD" styleClass="input"/>
                       </VBox>
                    </HBox>

                    <VBox spacing="8">
                        <Label text="ADDRESS" styleClass="form-label"/>
                        <TextField fx:id="addressField" promptText="Current permanent address" styleClass="input"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="NATIONAL ID / CITIZENSHIP" styleClass="form-label"/>
                        <TextField fx:id="nationalIdField" promptText="ID number" styleClass="input"/>
                    </VBox>

                    <Separator/>
                    <Label text="ACCOUNT SECURITY" styleClass="form-section-title"/>

                    <VBox spacing="8">
                        <Label text="EMAIL ADDRESS" styleClass="form-label"/>
                        <TextField fx:id="emailField" promptText="name@example.com" styleClass="input"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="PHONE NUMBER" styleClass="form-label"/>
                        <TextField fx:id="phoneField" promptText="+977" styleClass="input"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="SET PASSWORD" styleClass="form-label"/>
                        <PasswordField fx:id="passwordField" promptText="Choose a secure password" styleClass="input"/>
                    </VBox>

                    <VBox spacing="8" maxWidth="200">
                        <Label text="ACCOUNT TYPE" styleClass="form-label"/>
                        <ComboBox fx:id="accountTypeCombo" maxWidth="Infinity" styleClass="combo-box"/>
                    </VBox>
                    
                    <Label fx:id="errorLabel" styleClass="error" wrapText="true" alignment="CENTER" maxWidth="Infinity"/>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="Reset" onAction="#onClearForm" styleClass="secondary-btn" prefWidth="100"/>
                        <Button text="Create Account" onAction="#onRegister" styleClass="primary-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="48"/>
                    </HBox>
                </VBox>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Already have an account?" styleClass="body-small"/>
                    <Hyperlink text="Sign in instead" onAction="#onBackToLogin" styleClass="link" style="-fx-font-size: 13px;"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>

</StackPane>
