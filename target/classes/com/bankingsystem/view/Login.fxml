<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bankingsystem.controller.LoginController"
           style="-fx-background-color: #F8FAFC;">

    <VBox alignment="CENTER" spacing="32" maxWidth="450">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Brand Logo -->
        <VBox alignment="CENTER" spacing="12">
            <StackPane styleClass="logo-badge">
                <Label text="BF" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
            </StackPane>
            <VBox alignment="CENTER" spacing="4">
                <Label text="HamroBank" styleClass="hero-title"/>
                <Label text="Login to your secure banking portal" styleClass="tagline"/>
            </VBox>
        </VBox>

        <!-- Login Card -->
        <VBox styleClass="card" spacing="24">
            <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

            <VBox spacing="20">
                <VBox spacing="8">
                    <Label text="EMAIL OR PHONE" styleClass="form-label"/>
                    <TextField fx:id="usernameField" promptText="Enter email or phone number" styleClass="input"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="PASSWORD" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input"/>
                </VBox>
                
                <Label fx:id="errorLabel" styleClass="error" wrapText="true" alignment="CENTER" maxWidth="Infinity"/>

                <Button text="Login to Dashboard" onAction="#onLogin" 
                        styleClass="primary-btn" maxWidth="Infinity" prefHeight="48"/>
            </VBox>

            <HBox alignment="CENTER" spacing="8">
                <Label text="New to HamroBank?" styleClass="body-small"/>
                <Hyperlink text="Create an account" onAction="#onOpenRegister" styleClass="link" style="-fx-font-size: 13px;"/>
            </HBox>
        </VBox>

        <!-- Footer Info -->
        <VBox alignment="CENTER" spacing="8">
            <HBox alignment="CENTER" spacing="16">
                <Label text="Privacy" styleClass="micro" style="-fx-cursor: hand;"/>
                <Label text="Terms" styleClass="micro" style="-fx-cursor: hand;"/>
                <Label text="Help" styleClass="micro" style="-fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </VBox>

</StackPane>
